{
  "name": "Eulie",
  "productName": "Eulie",
  "version": "1.0.0",
  "description": "Eulie is an agent harness built on top of the Pi SDK.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "MAIN_WINDOW_VITE_DEV_SERVER_URL=http://localhost:5173 electron-forge start",
    "dev": "MAIN_WINDOW_VITE_DEV_SERVER_URL=http://localhost:5173 electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "copy-web-build": "shx cp -r ../web/dist/ dist-renderer/"
  },
  "keywords": [],
  "author": {
    "name": "Jonah Minihan",
    "email": "jonahminihan@gmail.com"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.0.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "electron": "41.4.0",
    "eslint": "^8.0.1",
    "eslint-plugin-import": "^2.25.0",
    "shared-types": "workspace:*",
    "shx": "^0.4.0",
    "typescript": "~4.5.4",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@tanstack/store": "^0.11.0",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "fix-path": "^5.0.0",
    "jiti": "^2.7.0",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
